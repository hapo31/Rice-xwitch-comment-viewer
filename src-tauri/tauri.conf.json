{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rice",
  "version": "0.1.0",
  "identifier": "dev.rice.tts",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rice",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 560,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
